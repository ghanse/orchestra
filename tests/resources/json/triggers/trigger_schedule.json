          "processDate": "@trigger().scheduledTime",
          "environment": "prod",
          "enableMerge": true
        }
      },
      {
        "pipelineReference": {
          "referenceName": "pipeline_complex_etl",
          "type": "PipelineReference"
        },
        "parameters": {
          "pipelineGroup": "finance",
          "processDate": "@trigger().scheduledTime",
          "environment": "prod",
