      { "name": "event_timestamp", "type": "INT96", "physicalType": "INT96" },
      { "name": "payload", "type": "UTF8", "physicalType": "UTF8" },
      { "name": "source_system", "type": "UTF8", "physicalType": "UTF8" },
      { "name": "partition_date", "type": "UTF8", "physicalType": "UTF8" }
